    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
